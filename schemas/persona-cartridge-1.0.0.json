{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archepersona.org/schemas/persona-cartridge-1.0.0.json",
  "title": "Persona Cartridge Specification v1.0.0",
  "description": "Canonical contract for portable Persona Cartridges generated by CHIMERA.",
  "type": "object",
  "required": [
    "manifest",
    "identity",
    "character",
    "preferences",
    "behavior",
    "communication",
    "status"
  ],
  "properties": {
    "manifest": {
      "type": "object",
      "required": [
        "cartridge_id",
        "schema_name",
        "schema_version",
        "specification_version",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "cartridge_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_name": {
          "type": "string",
          "const": "archepersona.chimera.persona-cartridge"
        },
        "schema_version": {
          "type": "string",
          "const": "0.6.0"
        },
        "specification_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "identity": {
      "type": "object",
      "required": [
        "display_name",
        "identifier",
        "summary"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "identifier": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "character": {
      "type": "object",
      "properties": {
        "core_values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "motivations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "goals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boundaries": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "preferences": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value", "scope", "priority", "description"],
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "value": {
                "type": ["string", "number", "boolean"]
              },
              "scope": {
                "type": "string",
                "enum": ["global", "contextual"]
              },
              "priority": {
                "type": "string",
                "enum": ["low", "normal", "high"]
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "behavior": {
      "type": "object",
      "required": ["policies"],
      "properties": {
        "policies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "identifier",
              "title",
              "description",
              "category",
              "policy_type",
              "enabled"
            ],
            "properties": {
              "identifier": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "enum": ["interaction", "reasoning", "safety", "workflow", "presentation"]
              },
              "policy_type": {
                "type": "string",
                "enum": ["required", "preferred", "prohibited"]
              },
              "enabled": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "communication": {
      "type": "object",
      "properties": {
        "communication_style": {
          "type": ["string", "null"]
        },
        "tone": {
          "type": "array",
          "items": { "type": "string" }
        },
        "vocabulary_preferences": {
          "type": "array",
          "items": { "type": "string" }
        },
        "response_tendencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "formatting_preferences": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reserved": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "state_modulations": {
      "type": "object"
    },
    "extensions": {
      "type": "object"
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
